POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Better Auth
BETTER_AUTH_SECRET=                   # generate: openssl rand -base64 32
